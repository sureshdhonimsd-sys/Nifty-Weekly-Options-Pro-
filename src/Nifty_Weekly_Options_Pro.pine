//@version=6
indicator("Nifty Weekly Options Pro v1.0", overlay=true)

//========== INPUTS ==========
emaFastLength = input.int(9, "Fast EMA")
emaSlowLength = input.int(20, "Slow EMA")

showVWAP = input.bool(true, "Show VWAP")

//========== EMA ==========
emaFast = ta.ema(close, emaFastLength)
emaSlow = ta.ema(close, emaSlowLength)

//========== VWAP ==========
vwapValue = ta.vwap(close)

//========== TREND ==========
bullTrend = emaFast > emaSlow and close > vwapValue
bearTrend = emaFast < emaSlow and close < vwapValue

//========== PLOTS ==========
plot(emaFast, title="EMA 9", color=color.green, linewidth=2)
plot(emaSlow, title="EMA 20", color=color.red, linewidth=2)
plot(showVWAP ? vwapValue : na, title="VWAP", color=color.blue, linewidth=2)

//========== BACKGROUND ==========
bgcolor(
     bullTrend ? color.new(color.green,90) :
     bearTrend ? color.new(color.red,90) :
     na)

//========== ALERTS ==========
alertcondition(bullTrend, title="Bull Trend", message="Bullish Trend")
alertcondition(bearTrend, title="Bear Trend", message="Bearish Trend")
